<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Game Ranker</title>
    <link rel="manifest" href="manifest.json">
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <style>
        :root { --bg: #0f172a; --card: #1e293b; --accent: #38bdf8; --text: #f1f5f9; }
        body { font-family: -apple-system, system-ui, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; }
        h1 { text-align: center; color: var(--accent); }
        #game-list { list-style: none; padding: 0; }
        .game-item { 
            background: var(--card); margin-bottom: 10px; padding: 15px; 
            border-radius: 12px; display: flex; align-items: center; 
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); cursor: grab;
        }
        .rank { font-weight: bold; font-size: 1.2rem; margin-right: 15px; color: var(--accent); min-width: 30px; }
        .game-info { flex-grow: 1; }
        .game-title { font-weight: 600; display: block; }
        
        /* Modal Styles */
        #modal { 
            display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); 
            padding: 20px; align-items: center; justify-content: center; z-index: 100;
        }
        .modal-content { background: var(--card); padding: 20px; border-radius: 15px; width: 100%; max-width: 400px; }
        textarea { width: 100%; height: 150px; background: #0f172a; color: white; border: 1px solid #334155; border-radius: 8px; padding: 10px; margin-top: 10px; box-sizing: border-box; }
        button { background: var(--accent); color: #0f172a; border: none; padding: 12px 20px; border-radius: 8px; font-weight: bold; margin-top: 10px; width: 100%; }
        .add-btn { background: #22c55e; margin-bottom: 20px; }
    </style>
</head>
<body>

    <h1>Game Rankings</h1>
    <button class="add-btn" onclick="addNewGame()">+ Add New Game</button>
    <ul id="game-list"></ul>

    <div id="modal">
        <div class="modal-content">
            <h2 id="modal-title">Game Review</h2>
            <textarea id="review-text" placeholder="What did you think of this game?"></textarea>
            <button onclick="saveReview()">Save Review</button>
            <button style="background:#ef4444; color:white;" onclick="closeModal()">Close</button>
        </div>
    </div>

    <script>
        let games = JSON.parse(localStorage.getItem('myGames')) || [];
        let currentEditingId = null;

        const list = document.getElementById('game-list');
        const modal = document.getElementById('modal');

        function render() {
            list.innerHTML = '';
            games.forEach((game, index) => {
                const li = document.createElement('li');
                li.className = 'game-item';
                li.setAttribute('data-id', game.id);
                li.innerHTML = `
                    <div class="rank">#${index + 1}</div>
                    <div class="game-info" onclick="openReview('${game.id}')">
                        <span class="game-title">${game.title}</span>
                        <small style="color:#94a3b8">${game.review ? 'Review written ✓' : 'Tap to add review...'}</small>
                    </div>
                `;
                list.appendChild(li);
            });
            localStorage.setItem('myGames', JSON.stringify(games));
        }

        // Drag and Drop Logic
        new Sortable(list, {
            animation: 150,
            onEnd: function() {
                const newOrder = Array.from(list.children).map(li => li.getAttribute('data-id'));
                games = newOrder.map(id => games.find(g => g.id === id));
                render();
            }
        });

        function addNewGame() {
            const title = prompt("Game Title:");
            if (title) {
                games.push({ id: Date.now().toString(), title, review: "" });
                render();
            }
        }

        function openReview(id) {
            currentEditingId = id;
            const game = games.find(g => g.id === id);
            document.getElementById('modal-title').innerText = game.title;
            document.getElementById('review-text').value = game.review;
            modal.style.display = 'flex';
        }

        function saveReview() {
            const game = games.find(g => g.id === currentEditingId);
            game.review = document.getElementById('review-text').value;
            closeModal();
            render();
        }

        function closeModal() { modal.style.display = 'none'; }

        // Register Service Worker for PWA
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('sw.js');
        }

        render();
    </script>
</body>
</html>
